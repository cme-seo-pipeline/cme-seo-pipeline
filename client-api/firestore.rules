rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Un client ne voit et ne modifie que son propre document.
    // Un admin voit et modifie tous les documents.
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();

      // Sous-collection des leads : meme regle d'isolation
      match /leads/{leadId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId) || isAdmin();

        match /{subcollection=**} {
          allow read: if isOwner(userId) || isAdmin();
          allow write: if isOwner(userId) || isAdmin();
        }
      }
    }

    // Collection group query : necessaire pour que le back-office admin
    // puisse lister TOUS les leads de TOUS les utilisateurs en une seule
    // requete (collectionGroup('leads')), plutot que de parcourir chaque
    // utilisateur un par un. Sans cette regle explicite au niveau racine,
    // la collection group query est refusee meme pour un admin legitime,
    // meme si la regle nichee ci-dessus l'autoriserait en acces direct.
    match /{path=**}/leads/{leadId} {
      allow read: if isAdmin();
    }

    // Tout le reste : refuse par defaut (principe du moindre privilege)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
